{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "capabilities for the game window: ffmpeg sidecar, temp-file fs, save dialog",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "binaries/ffmpeg", "sidecar": true, "args": true }
      ]
    },
    "dialog:allow-save",
    "dialog:allow-open",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-remove",
    "fs:allow-mkdir",
    {
      "identifier": "fs:scope",
      "allow": [{ "path": "$TEMP/**" }, { "path": "$APPDATA/**" }, { "path": "$APPLOCALDATA/**" }]
    }
  ]
}

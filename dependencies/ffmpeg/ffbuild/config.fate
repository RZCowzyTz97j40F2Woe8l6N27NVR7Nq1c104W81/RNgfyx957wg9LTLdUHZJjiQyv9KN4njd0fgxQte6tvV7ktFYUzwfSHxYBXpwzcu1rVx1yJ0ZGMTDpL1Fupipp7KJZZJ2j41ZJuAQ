config:x86:x86_64:generic:mingw32:gcc 15.2.0 (Rev13, Built by MSYS2 project):--disable-everything --disable-doc --disable-debug --disable-network --disable-autodetect --disable-ffprobe --disable-ffplay --enable-gpl --enable-libx264 --enable-small --enable-protocol='file,pipe' --enable-demuxer='rawvideo,wav,mov' --enable-muxer=mp4 --enable-decoder='rawvideo,pcm_s16le,pcm_f32le' --enable-encoder='libx264,aac' --enable-parser='h264,aac' --enable-filter='scale,format,aresample,aformat,anull,null' --enable-bsf=aac_adtstoasc --enable-swscale --enable-swresample --extra-ldflags=-static --pkg-config-flags=--static
